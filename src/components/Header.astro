---
import Wordmark from './Wordmark.astro';
import ThemeToggle from './ThemeToggle.astro';
import LangSwitch from './LangSwitch.astro';
import { getLocaleFromPath, t, getLocalePath } from '../lib/i18n';
import type { Locale } from '../lib/i18n';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath) as Locale;

const nav = [
  { label: t('nav.about', locale), href: getLocalePath(locale === 'de' ? '/ueber-mich' : '/about', locale) },
  { label: t('nav.expertise', locale), href: getLocalePath('/expertise', locale) },
  { label: t('nav.blog', locale), href: getLocalePath('/blog', locale) },
  { label: t('nav.now', locale), href: getLocalePath('/now', locale) },
  { label: t('nav.contact', locale), href: getLocalePath(locale === 'de' ? '/kontakt' : '/contact', locale) },
];
---
<header class="border-b border-neutral-border">
  <nav class="mx-auto flex max-w-2xl items-center justify-between px-6 py-5">
    <a href={getLocalePath('/', locale)}>
      <Wordmark />
    </a>

    <div class="hidden items-center gap-5 md:flex">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'text-sm transition-colors',
            currentPath === href
              ? 'text-neutral-fg'
              : 'text-neutral-muted hover:text-neutral-fg',
          ]}
        >
          {label}
        </a>
      ))}
      <LangSwitch />
      <ThemeToggle />
    </div>

    <div class="flex items-center gap-2 md:hidden">
      <LangSwitch />
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Menu"
        class="cursor-pointer p-1 text-neutral-muted"
      >
        <svg class="size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-neutral-border md:hidden">
    <div class="mx-auto flex max-w-2xl flex-col gap-1 px-6 py-4">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'py-2 text-sm',
            currentPath === href ? 'text-neutral-fg' : 'text-neutral-muted',
          ]}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</header>

<script is:inline>
  document.getElementById('mobile-menu-btn').addEventListener('click', function() {
    document.getElementById('mobile-menu').classList.toggle('hidden');
  });
</script>
