---
import Wordmark from './Wordmark.astro';
import ThemeToggle from './ThemeToggle.astro';
import LangSwitch from './LangSwitch.astro';
import { getLocaleFromPath, t, getLocalePath } from '../lib/i18n';
import type { Locale } from '../lib/i18n';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath) as Locale;

const nav = [
  { label: t('nav.about', locale), href: getLocalePath(locale === 'de' ? '/ueber-mich' : '/about', locale) },
  { label: t('nav.expertise', locale), href: getLocalePath('/expertise', locale) },
  { label: t('nav.blog', locale), href: getLocalePath('/blog', locale) },
  { label: t('nav.now', locale), href: getLocalePath('/now', locale) },
  { label: t('nav.contact', locale), href: getLocalePath(locale === 'de' ? '/kontakt' : '/contact', locale) },
];
---
<header class="sticky top-0 z-50 border-b border-neutral-border/50 bg-neutral-bg/90 backdrop-blur-md">
  <div class="accent-line"></div>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
    <a href={getLocalePath('/', locale)} class="transition-transform hover:scale-[1.02]">
      <Wordmark />
    </a>

    <!-- Desktop -->
    <div class="hidden items-center gap-1 md:flex">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'relative rounded-lg px-3 py-2 text-sm font-medium transition-all',
            currentPath === href
              ? 'text-brand-primary bg-brand-primary/8'
              : 'text-neutral-muted hover:text-neutral-fg hover:bg-neutral-surface',
          ]}
        >
          {label}
        </a>
      ))}
      <div class="ml-2 flex items-center gap-1 border-l border-neutral-border pl-3">
        <LangSwitch />
        <ThemeToggle />
      </div>
    </div>

    <!-- Mobile -->
    <div class="flex items-center gap-1 md:hidden">
      <LangSwitch />
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Menu"
        class="cursor-pointer rounded-lg p-2 text-neutral-muted transition-colors hover:bg-neutral-surface hover:text-neutral-fg"
      >
        <svg class="size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-neutral-border md:hidden">
    <div class="flex flex-col gap-1 px-4 py-3">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class:list={[
            'rounded-lg px-4 py-2.5 text-sm font-medium transition-all',
            currentPath === href
              ? 'text-brand-primary bg-brand-primary/8'
              : 'text-neutral-muted hover:bg-neutral-surface hover:text-neutral-fg',
          ]}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</header>

<script is:inline>
  document.getElementById('mobile-menu-btn').addEventListener('click', function() {
    document.getElementById('mobile-menu').classList.toggle('hidden');
  });
</script>
