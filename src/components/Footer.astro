---
import { getLocaleFromPath, t, getLocalePath } from '../lib/i18n';
import { STRALI_URL } from '../lib/constants';
import type { Locale } from '../lib/i18n';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath) as Locale;
const year = new Date().getFullYear();
---
<footer class="border-t border-neutral-border">
  <div class="mx-auto flex max-w-2xl flex-col gap-3 px-6 py-10 text-sm text-neutral-muted">
    <p>
      {t('footer.strali', locale)} —
      <a href={STRALI_URL} class="underline underline-offset-2 hover:text-neutral-fg" target="_blank" rel="noopener">strali.solutions</a>
    </p>
    <div class="flex gap-4">
      <a href={getLocalePath(locale === 'de' ? '/impressum' : '/imprint', locale)} class="hover:text-neutral-fg">
        {t('footer.imprint', locale)}
      </a>
      <a href={getLocalePath(locale === 'de' ? '/datenschutz' : '/privacy', locale)} class="hover:text-neutral-fg">
        {t('footer.privacy', locale)}
      </a>
      <a href={getLocalePath(locale === 'de' ? '/ki-transparenz' : '/ai-transparency', locale)} class="hover:text-neutral-fg">
        {t('footer.ai', locale)}
      </a>
    </div>
    <p class="text-neutral-muted/60">&copy; {year} Michael Linder</p>
  </div>
</footer>
