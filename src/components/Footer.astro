---
import { getLocaleFromPath, t, getLocalePath } from '../lib/i18n';
import { STRALI_URL } from '../lib/constants';
import type { Locale } from '../lib/i18n';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath) as Locale;
const year = new Date().getFullYear();
---
<footer class="border-t border-neutral-border">
  <div class="accent-line"></div>
  <div class="mx-auto max-w-6xl px-6 py-12 md:py-16">
    <div class="grid gap-8 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <img src="/logo.png" alt="rednil" class="h-10 w-auto" />
        <p class="mt-3 text-sm text-neutral-muted">
          {t('footer.strali', locale)}
          {' — '}
          <a href={STRALI_URL} class="underline underline-offset-2 transition-colors hover:text-brand-primary" target="_blank" rel="noopener">
            strali.solutions
          </a>
        </p>
      </div>

      <!-- Legal links -->
      <div>
        <p class="text-xs font-semibold tracking-wider text-neutral-muted uppercase">Legal</p>
        <div class="mt-3 flex flex-col gap-2">
          <a href={getLocalePath(locale === 'de' ? '/impressum' : '/imprint', locale)} class="text-sm text-neutral-muted transition-colors hover:text-neutral-fg">
            {t('footer.imprint', locale)}
          </a>
          <a href={getLocalePath(locale === 'de' ? '/datenschutz' : '/privacy', locale)} class="text-sm text-neutral-muted transition-colors hover:text-neutral-fg">
            {t('footer.privacy', locale)}
          </a>
        </div>
      </div>

      <!-- Copyright -->
      <div class="md:text-right">
        <p class="text-xs font-semibold tracking-wider text-neutral-muted uppercase">
          {locale === 'de' ? 'Kontakt' : 'Contact'}
        </p>
        <div class="mt-3 flex flex-col gap-2">
          <a href={getLocalePath(locale === 'de' ? '/kontakt' : '/contact', locale)} class="text-sm text-neutral-muted transition-colors hover:text-neutral-fg">
            {locale === 'de' ? 'Nachricht senden' : 'Get in touch'}
          </a>
        </div>
        <p class="mt-6 text-xs text-neutral-muted/70">&copy; {year} Michael Linder</p>
      </div>
    </div>
  </div>
</footer>
