---
import { getLocaleFromPath, t, getLocalePath } from '../lib/i18n';
import type { Locale } from '../lib/i18n';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath) as Locale;
const year = new Date().getFullYear();
---
<footer>
  <div class="mx-auto flex max-w-2xl flex-col gap-3 border-t border-neutral-border px-6 py-10 text-sm text-neutral-muted">
    <div class="flex gap-4">
      <a href={getLocalePath(locale === 'de' ? '/impressum' : '/imprint', locale)} class="hover:text-neutral-fg">
        {t('footer.imprint', locale)}
      </a>
      <a href={getLocalePath(locale === 'de' ? '/datenschutz' : '/privacy', locale)} class="hover:text-neutral-fg">
        {t('footer.privacy', locale)}
      </a>
      <a href={getLocalePath(locale === 'de' ? '/ki-transparenz' : '/ai-transparency', locale)} class="hover:text-neutral-fg">
        {t('footer.ai', locale)}
      </a>
    </div>
    <p class="text-neutral-muted/60">&copy; {year} Michael Linder · {locale === 'de' ? 'Gebaut mit' : 'Built with'} <a href="https://astro.build" target="_blank" rel="noopener" class="hover:text-neutral-fg">Astro</a>, <a href="https://tailwindcss.com" target="_blank" rel="noopener" class="hover:text-neutral-fg">Tailwind</a> & <a href="https://claude.ai/code" target="_blank" rel="noopener" class="hover:text-neutral-fg">Claude Code</a></p>
  </div>
</footer>
