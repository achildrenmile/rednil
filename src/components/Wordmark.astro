---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<!--
  Platzhalter-Wortmarke. Ersetzen durch echtes Logo:
  Option A: <img src="/logo.svg" alt="rednil" class="h-8" />
  Option B: SVG-Code direkt hier einfuegen
-->
<span
  class:list={[
    'font-display text-2xl font-bold tracking-tight text-neutral-fg',
    className,
  ]}
  aria-label="rednil"
>
  red<span class="text-brand-primary">nil</span>
</span>
