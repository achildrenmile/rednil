---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT_EMAIL } from '../lib/constants';
---
<BaseLayout title="Impressum" description="Impressum gemäß § 25 Mediengesetz.">
  <article class="py-12 md:py-20">
    <h1 class="font-display text-3xl font-bold tracking-tight md:text-4xl">Impressum</h1>

    <div class="prose mt-10">
      <p>Informationspflicht gemäß § 25 Mediengesetz.</p>

      <h2>Medieninhaber und Herausgeber</h2>
      <p>
        Strali Solutions e.U.<br />
        Michael Linder<br />
        Nötsch im Gailtal, Kärnten, Österreich<br />
        E-Mail: <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
      </p>

      <h2>Grundlegende Richtung</h2>
      <p>
        Persönliche Website und Blog. Alle Inhalte geben ausschließlich die Meinung des Autors wieder. Es besteht keine redaktionelle Anbindung an ein Unternehmen oder eine Organisation.
      </p>
    </div>
  </article>
</BaseLayout>
