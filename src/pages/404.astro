---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404">
  <div class="mx-auto flex max-w-3xl flex-col items-center px-6 py-24 text-center md:py-32">
    <p class="text-6xl font-bold text-brand-primary">404</p>
    <h1 class="mt-4 font-display text-2xl font-bold tracking-tight md:text-3xl">Seite nicht gefunden</h1>
    <p class="mt-4 text-neutral-muted">Die angeforderte Seite existiert nicht oder wurde verschoben.</p>
    <a href="/" class="mt-8 text-sm font-medium text-brand-primary hover:underline">&larr; Zur Startseite</a>
  </div>
</BaseLayout>
