---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { personSchema } from '../lib/jsonld';
import { GITHUB_URL, LINKEDIN_URL } from '../lib/constants';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'de' && !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat('de-AT', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout description="Solutions Architect mit 20+ Jahren Erfahrung. AI Governance, Platform Engineering, Enterprise IT im DACH-Raum." jsonLd={personSchema}>

  <section class="pt-8 pb-8 md:pt-12 md:pb-10">
    <div class="flex items-center gap-5">
      <img src="/michael.png" alt="Michael Linder" class="size-16 rounded-full md:size-20" />
      <h1 class="font-display text-3xl font-bold tracking-tight md:text-4xl">Servus, ich bin Michael</h1>
    </div>
    <p class="mt-4 text-lg leading-relaxed">
      Vater, Bastler und Funker aus Kärnten. Am liebsten am Berg, manchmal mit Funkgerät im Rucksack. Baut gern Dinge, die funktionieren.
    </p>
    <p class="mt-4 text-neutral-muted">
      Solutions Architect, AI Governance und Enterprise IT im DACH-Raum. Consultant bei <a href="https://strali.solutions" class="underline underline-offset-2 hover:text-neutral-fg" target="_blank" rel="noopener">Strali Solutions</a>.
    </p>
    <div class="mt-6 flex gap-4 text-sm">
      <a href={GITHUB_URL} class="text-neutral-muted hover:text-neutral-fg" target="_blank" rel="noopener">GitHub</a>
      <a href={LINKEDIN_URL} class="text-neutral-muted hover:text-neutral-fg" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://x.com/achildrenmile" class="text-neutral-muted hover:text-neutral-fg" target="_blank" rel="noopener">X</a>
      <a href="https://achildrenmile.github.io" class="text-neutral-muted hover:text-neutral-fg" target="_blank" rel="noopener">Tech Blog</a>
      <a href="/rss.xml" class="text-neutral-muted hover:text-neutral-fg">RSS</a>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="border-t border-neutral-border py-8 md:py-10">
      <h2 class="font-display text-xl font-bold tracking-tight">Aktuelle Beiträge</h2>
      <div class="mt-8 flex flex-col gap-8">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="group block">
            <time class="text-sm text-neutral-muted" datetime={post.data.pubDate.toISOString()}>
              {dateFormatter.format(post.data.pubDate)}
            </time>
            <h3 class="mt-1 font-display text-lg font-bold tracking-tight transition-colors group-hover:text-brand-primary">
              {post.data.title}
            </h3>
            <p class="mt-1 text-neutral-muted">{post.data.description}</p>
          </a>
        ))}
      </div>
      <a href="/blog" class="mt-8 inline-block text-sm text-brand-primary hover:underline">
        Alle Beiträge &rarr;
      </a>
    </section>
  )}

</BaseLayout>
