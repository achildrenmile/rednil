---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { personSchema } from '../lib/jsonld';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'de' && !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat('de-AT', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout description="Solutions Architect mit 20+ Jahren Erfahrung. AI Governance, Platform Engineering, Enterprise IT im DACH-Raum." jsonLd={personSchema}>

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Subtle grid background -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, currentColor 1px, transparent 0); background-size: 40px 40px;"></div>

    <div class="relative mx-auto grid max-w-6xl gap-12 px-6 pt-20 pb-16 md:grid-cols-5 md:items-center md:pt-28 md:pb-24 lg:pt-32 lg:pb-28">
      <!-- Text: 3 cols -->
      <div class="md:col-span-3">
        <div class="accent-line mb-8 w-16"></div>
        <p class="text-sm font-semibold tracking-widest text-brand-accent uppercase">
          Solutions Architect · AI Governance · Enterprise IT
        </p>
        <h1 class="mt-4 font-display text-4xl font-bold leading-[1.1] tracking-tight md:text-5xl lg:text-6xl">
          Michael<br />Linder
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-neutral-muted">
          Seit über zwanzig Jahren baue ich IT-Systeme für Unternehmen, die funktionieren müssen — nicht solche, die nur gut aussehen. Heute denke ich besonders über die Schnittstelle zwischen technischer Architektur, KI-Regulierung und unternehmerischer Verantwortung im DACH-Raum nach.
        </p>
        <p class="mt-8 border-l-2 border-brand-primary pl-4 font-display text-lg italic text-neutral-muted">
          Systeme verstehen. Lösungen bauen. Verantwortung übernehmen.
        </p>
      </div>

      <!-- Logo mark: 2 cols -->
      <div class="hidden md:col-span-2 md:flex md:justify-end">
        <div class="relative">
          <!-- Decorative ring -->
          <div class="absolute -inset-6 rounded-full border border-neutral-border/40"></div>
          <div class="absolute -inset-12 rounded-full border border-neutral-border/20"></div>
          <img src="/logo.png" alt="" class="relative h-48 w-48 object-contain lg:h-56 lg:w-56" aria-hidden="true" />
        </div>
      </div>
    </div>
  </section>

  <!-- Expertise teasers -->
  <section class="border-t border-neutral-border bg-neutral-surface">
    <div class="mx-auto grid max-w-6xl gap-px md:grid-cols-3">
      <a href="/expertise" class="group flex flex-col gap-3 border-b border-neutral-border bg-neutral-bg px-6 py-8 transition-colors hover:bg-neutral-surface md:border-b-0 md:border-r">
        <p class="text-xs font-semibold tracking-widest text-brand-primary uppercase">01</p>
        <h3 class="font-display text-lg font-bold">Platform Engineering</h3>
        <p class="text-sm text-neutral-muted">GitOps, ArgoCD, Helm, Tekton — reproduzierbare Deployments seit zwei Jahrzehnten.</p>
      </a>
      <a href="/expertise" class="group flex flex-col gap-3 border-b border-neutral-border bg-neutral-bg px-6 py-8 transition-colors hover:bg-neutral-surface md:border-b-0 md:border-r">
        <p class="text-xs font-semibold tracking-widest text-brand-primary uppercase">02</p>
        <h3 class="font-display text-lg font-bold">AI Governance</h3>
        <p class="text-sm text-neutral-muted">EU AI Act, Risikobewertung, Compliance-Architektur — pragmatisch, nicht bürokratisch.</p>
      </a>
      <a href="/expertise" class="group flex flex-col gap-3 bg-neutral-bg px-6 py-8 transition-colors hover:bg-neutral-surface">
        <p class="text-xs font-semibold tracking-widest text-brand-primary uppercase">03</p>
        <h3 class="font-display text-lg font-bold">Enterprise IT</h3>
        <p class="text-sm text-neutral-muted">20+ Jahre Querschnitt: .NET, Cloud, M365, DevOps, Sicherheitsarchitektur.</p>
      </a>
    </div>
  </section>

  <!-- Recent Posts -->
  {posts.length > 0 && (
    <section class="border-t border-neutral-border">
      <div class="mx-auto max-w-6xl px-6 py-16 md:py-24">
        <div class="flex items-end justify-between">
          <div>
            <div class="accent-line mb-4 w-10"></div>
            <h2 class="font-display text-2xl font-bold tracking-tight md:text-3xl">Aktuelle Beiträge</h2>
          </div>
          <a href="/blog" class="hidden text-sm font-medium text-brand-primary transition-colors hover:text-brand-accent md:block">
            Alle Beiträge &rarr;
          </a>
        </div>
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {posts.map((post) => (
            <article class="group rounded-xl border border-neutral-border bg-neutral-bg p-6 transition-all hover:border-brand-primary/30 hover:shadow-lg hover:shadow-brand-primary/5">
              <a href={`/blog/${post.id}`} class="flex h-full flex-col">
                <time class="text-xs font-medium text-neutral-muted" datetime={post.data.pubDate.toISOString()}>
                  {dateFormatter.format(post.data.pubDate)}
                </time>
                <h3 class="mt-3 font-display text-lg font-bold leading-snug tracking-tight transition-colors group-hover:text-brand-primary">
                  {post.data.title}
                </h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-muted">{post.data.description}</p>
                <div class="mt-4 flex flex-wrap gap-1.5">
                  {post.data.tags.map((tag) => (
                    <span class="rounded-md bg-neutral-surface px-2 py-0.5 text-[11px] font-medium text-neutral-muted">
                      {tag}
                    </span>
                  ))}
                </div>
              </a>
            </article>
          ))}
        </div>
        <a href="/blog" class="mt-8 inline-block text-sm font-medium text-brand-primary hover:underline md:hidden">
          Alle Beiträge &rarr;
        </a>
      </div>
    </section>
  )}
</BaseLayout>
