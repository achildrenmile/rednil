---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'de' && !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
const dateFormatter = new Intl.DateTimeFormat('de-AT', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title="Blog" description="Gedanken zu Platform Engineering, AI Governance und Enterprise IT.">
  <div class="mx-auto max-w-5xl px-6 py-16 md:py-24">
    <h1 class="font-display text-3xl font-bold tracking-tight md:text-4xl">Blog</h1>

    <!-- Tag filter -->
    {allTags.length > 0 && (
      <nav class="mt-6 flex flex-wrap gap-2" aria-label="Themen-Filter">
        {allTags.map((tag) => (
          <span class="rounded-full border border-neutral-border px-3 py-1 text-xs font-medium text-neutral-muted transition-colors hover:border-brand-primary hover:text-brand-primary">
            {tag}
          </span>
        ))}
      </nav>
    )}

    <!-- Posts -->
    <div class="mt-12 space-y-12">
      {posts.map((post) => (
        <article class="group">
          <a href={`/blog/${post.id}`} class="block">
            <div class="flex flex-wrap items-center gap-3 text-sm text-neutral-muted">
              <time datetime={post.data.pubDate.toISOString()}>
                {dateFormatter.format(post.data.pubDate)}
              </time>
              {post.data.tags.length > 0 && (
                <span class="text-neutral-border">|</span>
              )}
              {post.data.tags.map((tag) => (
                <span class="text-xs">{tag}</span>
              ))}
            </div>
            <h2 class="mt-2 font-display text-xl font-bold tracking-tight transition-colors group-hover:text-brand-primary md:text-2xl">
              {post.data.title}
            </h2>
            <p class="mt-2 text-neutral-muted">{post.data.description}</p>
          </a>
        </article>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="mt-12 text-neutral-muted">Noch keine Beiträge vorhanden.</p>
    )}
  </div>
</BaseLayout>
