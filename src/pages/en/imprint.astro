---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CONTACT_EMAIL } from '../../lib/constants';
---
<BaseLayout title="Imprint" description="Legal notice pursuant to § 5 ECG (Austrian E-Commerce Act).">
  <article class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    <h1 class="font-display text-3xl font-bold tracking-tight md:text-4xl">Imprint</h1>

    <div class="prose mt-10">
      <h2>Information pursuant to § 5 ECG</h2>

      <p>
        <strong>Michael Linder</strong><br />
        Strali Solutions e.U.<br />
        Noetsch im Gailtal<br />
        Carinthia, Austria
      </p>

      <p>
        <strong>Business activity:</strong> IT Services
      </p>

      <p>
        <strong>VAT ID:</strong> <code>{"{{UID_HIER}}"}</code><br />
        <strong>GISA number:</strong> <code>{"{{GISA_HIER}}"}</code>
      </p>

      <p>
        <strong>Contact:</strong><br />
        Email: <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
      </p>

      <p>
        <strong>Member of:</strong> Austrian Economic Chamber, Carinthia<br />
        <strong>Applicable law:</strong> Gewerbeordnung (GewO)<br />
        <strong>Supervisory authority:</strong> Bezirkshauptmannschaft Villach-Land
      </p>

      <h2>Disclaimer</h2>
      <p>
        Despite careful review, I assume no liability for the content of external links. The operators of linked pages are solely responsible for their content.
      </p>
    </div>
  </article>
</BaseLayout>
