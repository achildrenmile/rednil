---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
const dateFormatter = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title="Blog" description="Thoughts on Platform Engineering, AI Governance, and Enterprise IT.">
  <div class="py-5 md:py-8">
    <h1 class="font-display text-3xl font-bold tracking-tight md:text-4xl">Blog</h1>

    {allTags.length > 0 && (
      <nav class="mt-6 flex flex-wrap gap-2" aria-label="Topic filter">
        {allTags.map((tag) => (
          <button
            type="button"
            data-tag={tag}
            class="tag-btn cursor-pointer rounded-full border border-neutral-border px-3 py-1 text-xs font-medium text-neutral-muted transition-colors hover:border-brand-primary hover:text-brand-primary"
          >
            {tag}
          </button>
        ))}
      </nav>
    )}

    <div id="posts" class="mt-12 space-y-12">
      {posts.map((post) => (
        <article class="group" data-tags={post.data.tags.join(',')}>
          <a href={`/en/blog/${post.id.replace(/^en\//, '')}`} class="block">
            <div class="flex flex-wrap items-center gap-3 text-sm text-neutral-muted">
              <time datetime={post.data.pubDate.toISOString()}>
                {dateFormatter.format(post.data.pubDate)}
              </time>
              {post.data.tags.length > 0 && (
                <span class="text-neutral-border">|</span>
              )}
              {post.data.tags.map((tag) => (
                <span class="text-xs">{tag}</span>
              ))}
            </div>
            <h2 class="mt-2 font-display text-xl font-bold tracking-tight transition-colors group-hover:text-brand-primary md:text-2xl">
              {post.data.title}
            </h2>
            <p class="mt-2 text-neutral-muted">{post.data.description}</p>
          </a>
        </article>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="mt-12 text-neutral-muted">No posts yet.</p>
    )}
  </div>
</BaseLayout>

<script is:inline>
  (function() {
    var active = null;
    document.querySelectorAll('.tag-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var tag = btn.getAttribute('data-tag');
        if (active === tag) {
          active = null;
          document.querySelectorAll('.tag-btn').forEach(function(b) {
            b.classList.remove('border-brand-primary', 'text-brand-primary');
            b.classList.add('border-neutral-border', 'text-neutral-muted');
          });
          document.querySelectorAll('#posts article').forEach(function(a) {
            a.style.display = '';
          });
        } else {
          active = tag;
          document.querySelectorAll('.tag-btn').forEach(function(b) {
            if (b.getAttribute('data-tag') === tag) {
              b.classList.add('border-brand-primary', 'text-brand-primary');
              b.classList.remove('border-neutral-border', 'text-neutral-muted');
            } else {
              b.classList.remove('border-brand-primary', 'text-brand-primary');
              b.classList.add('border-neutral-border', 'text-neutral-muted');
            }
          });
          document.querySelectorAll('#posts article').forEach(function(a) {
            var tags = a.getAttribute('data-tags').split(',');
            a.style.display = tags.indexOf(tag) >= 0 ? '' : 'none';
          });
        }
      });
    });
  })();
</script>
