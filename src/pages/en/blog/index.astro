---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
const dateFormatter = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title="Blog" description="Thoughts on Platform Engineering, AI Governance, and Enterprise IT.">
  <div class="py-12 md:py-20">
    <h1 class="font-display text-3xl font-bold tracking-tight md:text-4xl">Blog</h1>

    {allTags.length > 0 && (
      <nav class="mt-6 flex flex-wrap gap-2" aria-label="Topic filter">
        {allTags.map((tag) => (
          <span class="rounded-full border border-neutral-border px-3 py-1 text-xs font-medium text-neutral-muted transition-colors hover:border-brand-primary hover:text-brand-primary">
            {tag}
          </span>
        ))}
      </nav>
    )}

    <div class="mt-12 space-y-12">
      {posts.map((post) => (
        <article class="group">
          <a href={`/en/blog/${post.id.replace(/^en\//, '')}`} class="block">
            <div class="flex flex-wrap items-center gap-3 text-sm text-neutral-muted">
              <time datetime={post.data.pubDate.toISOString()}>
                {dateFormatter.format(post.data.pubDate)}
              </time>
              {post.data.tags.length > 0 && (
                <span class="text-neutral-border">|</span>
              )}
              {post.data.tags.map((tag) => (
                <span class="text-xs">{tag}</span>
              ))}
            </div>
            <h2 class="mt-2 font-display text-xl font-bold tracking-tight transition-colors group-hover:text-brand-primary md:text-2xl">
              {post.data.title}
            </h2>
            <p class="mt-2 text-neutral-muted">{post.data.description}</p>
          </a>
        </article>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="mt-12 text-neutral-muted">No posts yet.</p>
    )}
  </div>
</BaseLayout>
