---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { personSchema } from '../../lib/jsonld';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout description="Solutions Architect with 20+ years of experience. AI Governance, Platform Engineering, Enterprise IT in the DACH region." jsonLd={personSchema}>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-6 pt-24 pb-16 md:pt-32 md:pb-24">
    <div class="max-w-3xl">
      <p class="mb-4 text-sm font-medium tracking-wide text-brand-primary uppercase">
        Solutions Architect · AI Governance · Enterprise IT
      </p>
      <h1 class="font-display text-4xl font-bold leading-tight tracking-tight md:text-5xl lg:text-6xl">
        Michael Linder
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-neutral-muted md:text-xl">
        For over twenty years I've built enterprise IT systems that have to work — not just look good. These days I think a lot about where technical architecture, AI regulation, and business responsibility meet, especially in the DACH region.
      </p>
      <p class="mt-8 font-display text-lg italic text-neutral-muted">
        Understand systems. Build solutions. Take responsibility.
      </p>
    </div>
  </section>

  <!-- Recent Posts -->
  {posts.length > 0 && (
    <section class="border-t border-neutral-border">
      <div class="mx-auto max-w-5xl px-6 py-16 md:py-24">
        <h2 class="font-display text-2xl font-bold tracking-tight md:text-3xl">Recent Posts</h2>
        <div class="mt-10 space-y-10">
          {posts.map((post) => (
            <article class="group">
              <a href={`/en/blog/${post.id.replace(/^en\//, '')}`} class="block">
                <time class="text-sm text-neutral-muted" datetime={post.data.pubDate.toISOString()}>
                  {dateFormatter.format(post.data.pubDate)}
                </time>
                <h3 class="mt-1 font-display text-xl font-bold tracking-tight transition-colors group-hover:text-brand-primary md:text-2xl">
                  {post.data.title}
                </h3>
                <p class="mt-2 text-neutral-muted">{post.data.description}</p>
              </a>
            </article>
          ))}
        </div>
        <a href="/en/blog" class="mt-10 inline-block text-sm font-medium text-brand-primary hover:underline">
          All posts &rarr;
        </a>
      </div>
    </section>
  )}
</BaseLayout>
